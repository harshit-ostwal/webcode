{
  "name": "backend",
  "version": "0.1.0",
  "description": "Production-ready backend using Bun",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": {
    "name": "Harshit Ostwal",
    "email": "harshitostwal1234@gmail.com",
    "url": "https://harshitostwal.com"
  },
  "contributors": [
    {
      "name": "Harshit Ostwal",
      "email": "harshitostwal1234@gmail.com",
      "url": "https://harshitostwal.com"
    }
  ],
  "main": "src/index.js",
  "module": "src/index.js",
  "scripts": {
    "dev:nodemon": "cross-env NODE_ENV=development nodemon src/index.js",
    "dev": "cross-env NODE_ENV=development bun --hot src/index.js",
    "start": "cross-env NODE_ENV=production bun src/index.js",
    "biome:format": "bunx biome format --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none",
    "biome:lint": "bunx biome lint --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none",
    "biome:check": "bunx biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none",
    "biome:clean": "bunx biome clean",
    "prepare": "husky"
  },
  "lint-staged": {
    "*": [
      "bunx biome check --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none",
      "bunx biome format --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none",
      "bunx biome lint --write --no-errors-on-unmatched --files-ignore-unknown=true --max-diagnostics=none"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "8",
    "morgan": "^1.11.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.2",
    "slugify": "^1.6.9",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "nodemon": "^3.1.14"
  }
}
